# Weather History Production Environment Template
# Copy to /var/www/weather-history/.env.production on Hetzner server
# DO NOT commit this file to git!

APP_ENV=production
APP_DEBUG=false
APP_NAME="Weather History Deutschland"

# Domains
APP_DOMAIN=weather.elmarhepp.de
API_DOMAIN=weather-api.elmarhepp.de

# Database
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=weather_history
DB_USERNAME=weather_user
DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD_HERE

# Redis Cache
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Laravel
APP_KEY=base64:jxwGV8A4TenqVpBJ8MQqjVQM7K9pnAOhJ+kkRPh9J6w=
APP_URL=https://weather-api.elmarhepp.de

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=info

# Cache
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Mail (optional)
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@weather.elmarhepp.de
MAIL_FROM_NAME="Weather History"
