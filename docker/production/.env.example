# Weather History DWD - Production Environment Variables
# Copy this file to .env and fill in the values

# Database Configuration
DB_PASSWORD=your_secure_database_password_here

# Application URLs
APP_URL=https://wetter-dwd-api.elmarhepp.de
API_URL=https://wetter-dwd-api.elmarhepp.de/api
VITE_API_BASE_URL=https://wetter-dwd-api.elmarhepp.de/api

# Laravel Application Key
APP_KEY=base64:generate_with_php_artisan_key_generate

# Application Environment
APP_ENV=production
APP_DEBUG=false

# Database Connection
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=weather_history
DB_USERNAME=weather_user

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=error

# Session Configuration
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Cache Configuration
CACHE_DRIVER=redis

# Queue Configuration
QUEUE_CONNECTION=redis

# Mail Configuration (optional)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@wetter-dwd.elmarhepp.de"
MAIL_FROM_NAME="${APP_NAME}"

# Application Name
APP_NAME="Weather History DWD"

# Security
SANCTUM_STATEFUL_DOMAINS=wetter-dwd.elmarhepp.de
SESSION_DOMAIN=.elmarhepp.de

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://wetter-dwd.elmarhepp.de

# Rate Limiting
RATE_LIMIT=60,1

# Hetzner Deployment Ports
WEB_PORT=3031
API_PORT=3032
ADMINER_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379